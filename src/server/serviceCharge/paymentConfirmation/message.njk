{% extends 'layouts/page.njk' %}

{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ appHeading(heading) }}
    </div>

    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body govuk-!-margin-top-3" data-testid="payment-pending-summaryContent">{{ summaryContent }}</p>

      {% if whatHappensNextHeading %}
        <h2 class="govuk-heading-m " data-testid="payment-next-steps-heading">{{ whatHappensNextHeading }}</h2>
      {% endif %}

      {% if whatHappensNext %}
        {% for nextStep in whatHappensNext %}
          <p class="govuk-body" data-testid="payment-next-step">{{ nextStep }}</p>
        {% endfor %}
      {% endif %}

      <a class="govuk-link" href="{{ returnToAccountLink }}" data-testid="payment-return-link">{{ returnToAccountLabel }}</a>
    </div>
  </div>
{% endblock %}
