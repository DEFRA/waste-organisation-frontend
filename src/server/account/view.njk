{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  <div class="govuk-!-margin-bottom-6">
    {% if isServiceChargeEnabled %}

      {% if paymentStatus.disabled %}

        {% set importantNoticeHtml %}
        {{ importantNotice.bodyPrefix }}
        <a href="{{ apiListHref }}" class="govuk-link govuk-link--no-visited-state" data-testid="important-notice-api-link">
          {{ importantNotice.manageApiCode }}
        </a>{{ importantNotice.bodySuffix }}
        {% endset %}

        {{ appImportantBanner({
          title: importantNotice.title,
          heading: importantNotice.heading,
          content: importantNotice.body
        }) }}
      {% endif %}
    {% endif %}

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {{ govukButton({
          text: switchOrganisation,
          classes: "govuk-button--secondary",
          href: switchOrganisationHref,
          attributes: {
            "data-testid": "switch-organisation-button"
          }
        }) }}

        {{ appHeading(heading) }}
      </div>
    </div>

    <div class="govuk-grid-row govuk-card-row govuk-!-margin-top-8" data-testid="account-cards">
      <div class="govuk-grid-column-one-third">
        <div class="govuk-card govuk-card--contained">
          <div class="govuk-card__content">
            <h2 class="govuk-heading-m">
              <a href="{{ reportWasteHref }}" class="govuk-link govuk-link--no-visited-state" data-testid="report-waste-link">
                {{ cards.reportWaste.text }}
              </a>
            </h2>
          </div>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-card govuk-card--contained">
          <div class="govuk-card__content">
            <h2 class="govuk-heading-m">
              <a href="{{ manageAccountHref }}" class="govuk-link govuk-link--no-visited-state" data-testid="manage-account-link">
                {{ cards.manageAccount.text }}
              </a>
            </h2>
          </div>
        </div>
      </div>
      {% if isServiceChargeEnabled %}
        <div class="govuk-grid-column-one-third">
          <div class="govuk-card govuk-card--contained">
            <div class="govuk-card__content">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-3">
                {% if paymentStatus.canPay %}
                  <a href="{{ serviceChargeHref }}" class="govuk-link govuk-link--no-visited-state" data-testid="service-charge-link">
                    {{ cards.serviceCharge.text }}
                  </a>
                {% else %}
                  {{ cards.serviceCharge.text }}
                {% endif %}
              </h2>
            </div>
            <div class="govuk-card__actions" data-testid="service-charge-next-payment-due">

              {{ govukTag({
                  text: paymentStatus.label,
                  classes: paymentStatus.tagClass
                }) 
              }}

              {% if paymentStatus.nextDue %}
                <p class="govuk-body govuk-!-margin-top-4 govuk-!-margin-bottom-0" >
                  {{ cards.serviceCharge.nextPaymentDue + ' ' + paymentStatus.nextDue }}.
                  {% if paymentStatus.canPay %}
                    <a href="{{ serviceChargeHref }}" class="govuk-link govuk-link--no-visited-state" data-testid="service-charge-pay-now-link">{{cards.serviceCharge.payNow}}</a>.
                  {% endif %}
                </p>
              {% endif %}
            </div>
          </div>
        </div>

      {% else %}

        <div class="govuk-grid-column-one-third">
          <div class="govuk-card govuk-card--contained">
            <div class="govuk-card__content">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-3">
                <span data-testid="service-charge-text">{{ cards.serviceCharge.text }}</span>
              </h2>
            </div>
            <div class="govuk-card__actions">
              {{ govukTag({
                text: cards.serviceCharge.tag,
                classes: "govuk-tag--yellow",
                attributes: {
                  "data-testid": "service-charge-due-date"
                }
            }) }}
            </div>
          </div>
        </div>

      {% endif %}

    </div>
  </div>
{% endblock %}