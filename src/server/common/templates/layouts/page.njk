{% extends "govuk/template.njk" %}

{# Import GOVUK components globally #}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}

{# Import custom components globally #}
{% from "heading/macro.njk" import appHeading %}

{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% block head %}
  {% if govukRebrand == false %}
    <link
    href="{{ getAssetPath('stylesheets/application-black.scss')}}"
    rel="stylesheet"
/>
    <link rel="icon" href="{{ getAssetPath('assets/images/favicon.png') }}" type="image/png">
    <link rel="apple-touch-icon" href="{{ getAssetPath('assets/images/favicon.png') }}">
  {% else %}
    <link
    href="{{ getAssetPath('stylesheets/application.scss')}}"
    rel="stylesheet"
/>
  {% endif %}

{% endblock %}

{% block header %}
  {# serviceName being used in govukHeader will be @deprecated in v6. It has moved to govukServiceNavigation - https://github.com/alphagov/govuk-frontend/blob/main/CHANGELOG.md#move-service-name-and-navigation-links-from-the-govuk-header-to-service-navigation-component #}

  {% if govukRebrand == false %}
    <div class="govuk-header">
      <div class="govuk-header__container govuk-width-container">
        <div class="govuk-header__logo">
          <a href="{{serviceUrl}}" class="govuk-header__homepage-link">
            Department for Environment, Food and Rural Affairs
          </a>
        </div>
      </div>
    </div>
  {% else %}
    {{
    govukHeader({
      homepageUrl: "https://www.gov.uk/",
      classes: "app-header",
      containerClasses: "govuk-width-container",
      useTudorCrown: true
    })
  }}
  {% endif %}

  {{
    govukServiceNavigation({
      serviceName: serviceName,
      serviceUrl: serviceUrl,
      navigation: navigation,
      classes: "govuk-!-margin-bottom-2"
    })
  }}
{% endblock %}

{% block pageTitle %}
  {{ pageTitle }} | {{ serviceName }}
{% endblock %}

{% block beforeContent %}

  {% set phaseHtml %}
    This is a new service. Help us improve it and <a class="govuk-link" href="{{feedbackUrl}}" target="_blank" rel="noopener noreferrer" data-testid="feedback-link">give your feedback (opens in new tab)</a>.
  {% endset -%}

  {{
    govukPhaseBanner({
    tag: {
      text: "Beta"
    },
    html: phaseHtml
    })
  }}

  {% if breadcrumbs.length > 1 %}
    {{
      govukBreadcrumbs({
        items: breadcrumbs
      })
    }}
  {% endif %}

  {% if backLink %}
    {{ govukBackLink({
      text: "Back",
      href: backLink,
      attributes: {
        "data-testid": "back-link"
      }
    }) }}
  {% endif %}
{% endblock %}

{% block content %}{% endblock %}

{% block footer %}
  {{
    govukFooter({
      meta: {
        items: [
          {
            href: "/privacy-notice",
            text: "Privacy"
          },
          {
            href: "/cookies",
            text: "Cookies"
          },
          {
            href: "https://www.gov.uk/help/accessibility-statement",
            text: "Accessibility statement"
          },
          {
            href: "/terms",
            text: "Terms"
          }
        ]
      }
    })
  }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ getAssetPath('application.js') }}"></script>
{% endblock %}
