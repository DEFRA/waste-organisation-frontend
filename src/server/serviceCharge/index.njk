{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="service-charge-heading">{{ heading }}</h1>
      <p class="govuk-body" data-testid="service-charge-cost">{{ cost }}</p>
      <p class="govuk-body" data-testid="service-charge-requirements-intro">{{ requirementsIntro }}</p>

      <ul class="govuk-list govuk-list--bullet" data-testid="service-charge-requirements">
        {% for requirement in requirements %}
          <li>{{ requirement }}</li>
        {% endfor %}
      </ul>

      {{ govukWarningText({
        text: warning,
        iconFallbackText: "Important",
        classes: "govuk-!-margin-top-6 govuk-!-margin-bottom-7",
        attributes: {
          "data-testid": "service-charge-warning"
        }
      }) }}

      <div class="govuk-button-group">
        {{ govukButton({
          text: payServiceCharge,
          type: "button",
          attributes: {
            "data-testid": "pay-service-charge-button"
          }
        }) }}
        <a class="govuk-link" href="{{ cancelLink.href }}" data-testid="service-charge-cancel-link">{{ cancelLink.text }}</a>
      </div>
    </div>
  </div>
{% endblock %}
