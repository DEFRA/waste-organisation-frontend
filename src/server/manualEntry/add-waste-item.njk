{% extends 'layouts/page.njk' %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% set popsConditionalHtml %}
  {{ govukInput({
    id: "popsComponents",
    name: "popsComponents",
    value: values.popsComponents,
    label: { text: "POPs components" },
    hint: { text: "Enter in the format: code=concentration, for example: PBDE=0.5. Separate multiple with a semicolon." },
    errorMessage: errors.popsComponents
  }) }}
  {{ govukInput({
    id: "popsSource",
    name: "popsSource",
    value: values.popsSource,
    label: { text: "Source of POPs components" },
    errorMessage: errors.popsSource
  }) }}
{% endset %}

{% set hazConditionalHtml %}
  {{ govukInput({
    id: "hazCodes",
    name: "hazCodes",
    value: values.hazCodes,
    label: { text: "Hazardous waste codes" },
    hint: { text: "Enter codes separated by commas, for example: HP1, HP2" },
    errorMessage: errors.hazCodes
  }) }}
  {{ govukInput({
    id: "hazComponents",
    name: "hazComponents",
    value: values.hazComponents,
    label: { text: "Hazardous components" },
    hint: { text: "Enter in the format: name=concentration, for example: Lead=0.5. Separate multiple with a semicolon." },
    errorMessage: errors.hazComponents
  }) }}
  {{ govukInput({
    id: "hazSource",
    name: "hazSource",
    value: values.hazSource,
    label: { text: "Source of hazardous components" },
    errorMessage: errors.hazSource
  }) }}
{% endset %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorList.length %}
        {{ govukErrorSummary({
          titleText: errorTitle,
          errorList: errorList
        }) }}
      {% endif %}

      {{ appHeading(heading) }}

      <form action="{{ action.url }}" method="POST" novalidate>

        {{ govukInput({
          id: "ewcCodes",
          name: "ewcCodes",
          value: values.ewcCodes,
          label: { text: "EWC codes" },
          hint: { text: "Enter codes separated by commas, for example: 010101, 010102" },
          errorMessage: errors.ewcCodes
        }) }}

        {{ govukTextarea({
          id: "wasteDescription",
          name: "wasteDescription",
          value: values.wasteDescription,
          rows: 3,
          label: { text: "Waste description" },
          errorMessage: errors.wasteDescription
        }) }}

        {{ govukSelect({
          id: "physicalForm",
          name: "physicalForm",
          label: { text: "Physical form" },
          errorMessage: errors.physicalForm,
          items: [
            { value: "", text: "Select", selected: not values.physicalForm },
            { value: "Gas", text: "Gas", selected: values.physicalForm === "Gas" },
            { value: "Liquid", text: "Liquid", selected: values.physicalForm === "Liquid" },
            { value: "Solid", text: "Solid", selected: values.physicalForm === "Solid" },
            { value: "Mixed", text: "Mixed", selected: values.physicalForm === "Mixed" },
            { value: "Sludge", text: "Sludge", selected: values.physicalForm === "Sludge" },
            { value: "Powder", text: "Powder", selected: values.physicalForm === "Powder" }
          ]
        }) }}

        {{ govukInput({
          id: "numberOfContainers",
          name: "numberOfContainers",
          value: values.numberOfContainers,
          inputmode: "numeric",
          classes: "govuk-input--width-4",
          label: { text: "Number of containers" },
          errorMessage: errors.numberOfContainers
        }) }}

        {{ govukSelect({
          id: "typeOfContainers",
          name: "typeOfContainers",
          label: { text: "Type of containers" },
          errorMessage: errors.typeOfContainers,
          items: [
            { value: "", text: "Select", selected: not values.typeOfContainers },
            { value: "DRUM", text: "Drum", selected: values.typeOfContainers === "DRUM" },
            { value: "IBC", text: "IBC (Intermediate Bulk Container)", selected: values.typeOfContainers === "IBC" },
            { value: "TANK", text: "Tank", selected: values.typeOfContainers === "TANK" },
            { value: "SKIP", text: "Skip", selected: values.typeOfContainers === "SKIP" },
            { value: "BULK", text: "Bulk", selected: values.typeOfContainers === "BULK" },
            { value: "BAG", text: "Bag", selected: values.typeOfContainers === "BAG" },
            { value: "BOX", text: "Box", selected: values.typeOfContainers === "BOX" },
            { value: "OTHER", text: "Other", selected: values.typeOfContainers === "OTHER" }
          ]
        }) }}

        {{ govukSelect({
          id: "weightMetric",
          name: "weightMetric",
          label: { text: "Weight metric" },
          errorMessage: errors.weightMetric,
          items: [
            { value: "", text: "Select", selected: not values.weightMetric },
            { value: "Grams", text: "Grams", selected: values.weightMetric === "Grams" },
            { value: "Kilograms", text: "Kilograms", selected: values.weightMetric === "Kilograms" },
            { value: "Tonnes", text: "Tonnes", selected: values.weightMetric === "Tonnes" }
          ]
        }) }}

        {{ govukInput({
          id: "weightAmount",
          name: "weightAmount",
          value: values.weightAmount,
          inputmode: "decimal",
          classes: "govuk-input--width-10",
          label: { text: "Weight amount" },
          hint: { text: "Enter the weight as a number" },
          errorMessage: errors.weightAmount
        }) }}

        {{ govukRadios({
          name: "weightIsEstimate",
          classes: "govuk-radios--inline",
          fieldset: {
            legend: {
              text: "Is this weight an estimate or actual?",
              classes: "govuk-fieldset__legend--s"
            }
          },
          errorMessage: errors.weightIsEstimate,
          items: [
            { value: "estimate", text: "Estimate", checked: values.weightIsEstimate === "estimate" },
            { value: "actual", text: "Actual", checked: values.weightIsEstimate === "actual" }
          ]
        }) }}

        {{ govukRadios({
          name: "containsPops",
          fieldset: {
            legend: {
              text: "Does the waste contain persistent organic pollutants (POPs)?",
              classes: "govuk-fieldset__legend--s"
            }
          },
          errorMessage: errors.containsPops,
          items: [
            {
              value: "yes",
              text: "Yes",
              checked: values.containsPops === "yes",
              conditional: { html: popsConditionalHtml }
            },
            { value: "no", text: "No", checked: values.containsPops === "no" }
          ]
        }) }}

        {{ govukRadios({
          name: "containsHazardous",
          fieldset: {
            legend: {
              text: "Does the waste contain hazardous materials?",
              classes: "govuk-fieldset__legend--s"
            }
          },
          errorMessage: errors.containsHazardous,
          items: [
            {
              value: "yes",
              text: "Yes",
              checked: values.containsHazardous === "yes",
              conditional: { html: hazConditionalHtml }
            },
            { value: "no", text: "No", checked: values.containsHazardous === "no" }
          ]
        }) }}

        {% call govukFieldset({
          legend: {
            text: "Disposal or recovery code",
            classes: "govuk-fieldset__legend--s"
          }
        }) %}

          {{ govukSelect({
            id: "disposalCode",
            name: "disposalCode",
            label: { text: "Code" },
            errorMessage: errors.disposalCode,
            items: [
              { value: "", text: "Select", selected: not values.disposalCode },
              { value: "R1", text: "R1 - Use principally as a fuel", selected: values.disposalCode === "R1" },
              { value: "R2", text: "R2 - Solvent reclamation", selected: values.disposalCode === "R2" },
              { value: "R3", text: "R3 - Recycling organic substances", selected: values.disposalCode === "R3" },
              { value: "R4", text: "R4 - Recycling metals", selected: values.disposalCode === "R4" },
              { value: "R5", text: "R5 - Recycling inorganic materials", selected: values.disposalCode === "R5" },
              { value: "R6", text: "R6 - Regeneration of acids or bases", selected: values.disposalCode === "R6" },
              { value: "R7", text: "R7 - Recovery of pollution abatement components", selected: values.disposalCode === "R7" },
              { value: "R8", text: "R8 - Recovery of catalyst components", selected: values.disposalCode === "R8" },
              { value: "R9", text: "R9 - Oil re-refining", selected: values.disposalCode === "R9" },
              { value: "R10", text: "R10 - Land treatment", selected: values.disposalCode === "R10" },
              { value: "R11", text: "R11 - Use of waste from R1 to R10", selected: values.disposalCode === "R11" },
              { value: "R12", text: "R12 - Exchange of waste for R1 to R11", selected: values.disposalCode === "R12" },
              { value: "R13", text: "R13 - Storage pending R1 to R12", selected: values.disposalCode === "R13" },
              { value: "D1", text: "D1 - Deposit into or onto land", selected: values.disposalCode === "D1" },
              { value: "D2", text: "D2 - Land treatment", selected: values.disposalCode === "D2" },
              { value: "D3", text: "D3 - Deep injection", selected: values.disposalCode === "D3" },
              { value: "D4", text: "D4 - Surface impoundment", selected: values.disposalCode === "D4" },
              { value: "D5", text: "D5 - Specially engineered landfill", selected: values.disposalCode === "D5" },
              { value: "D6", text: "D6 - Release into a water body", selected: values.disposalCode === "D6" },
              { value: "D7", text: "D7 - Release into seas or oceans", selected: values.disposalCode === "D7" },
              { value: "D8", text: "D8 - Biological treatment", selected: values.disposalCode === "D8" },
              { value: "D9", text: "D9 - Physico-chemical treatment", selected: values.disposalCode === "D9" },
              { value: "D10", text: "D10 - Incineration on land", selected: values.disposalCode === "D10" },
              { value: "D11", text: "D11 - Incineration at sea", selected: values.disposalCode === "D11" },
              { value: "D12", text: "D12 - Permanent storage", selected: values.disposalCode === "D12" },
              { value: "D13", text: "D13 - Blending or mixing prior to D1 to D12", selected: values.disposalCode === "D13" },
              { value: "D14", text: "D14 - Repackaging prior to D1 to D13", selected: values.disposalCode === "D14" },
              { value: "D15", text: "D15 - Storage pending D1 to D14", selected: values.disposalCode === "D15" }
            ]
          }) }}

          {{ govukInput({
            id: "disposalAmount",
            name: "disposalAmount",
            value: values.disposalAmount,
            inputmode: "decimal",
            classes: "govuk-input--width-10",
            label: { text: "Amount" },
            errorMessage: errors.disposalAmount
          }) }}

          {{ govukSelect({
            id: "disposalMetric",
            name: "disposalMetric",
            label: { text: "Metric" },
            errorMessage: errors.disposalMetric,
            items: [
              { value: "", text: "Select", selected: not values.disposalMetric },
              { value: "Grams", text: "Grams", selected: values.disposalMetric === "Grams" },
              { value: "Kilograms", text: "Kilograms", selected: values.disposalMetric === "Kilograms" },
              { value: "Tonnes", text: "Tonnes", selected: values.disposalMetric === "Tonnes" }
            ]
          }) }}

          {{ govukRadios({
            name: "disposalIsEstimate",
            classes: "govuk-radios--inline",
            fieldset: {
              legend: {
                text: "Is this an estimate or actual?",
                classes: "govuk-fieldset__legend--s"
              }
            },
            errorMessage: errors.disposalIsEstimate,
            items: [
              { value: "estimate", text: "Estimate", checked: values.disposalIsEstimate === "estimate" },
              { value: "actual", text: "Actual", checked: values.disposalIsEstimate === "actual" }
            ]
          }) }}

        {% endcall %}

        {{ govukButton({
          text: action.text,
          type: "submit",
          attributes: {
            "data-testid": "waste-item-submit-button"
          }
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
