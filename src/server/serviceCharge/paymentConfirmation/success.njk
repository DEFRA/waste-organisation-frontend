{% extends 'layouts/page.njk' %}

{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set paymentSummaryRows = [
  {
    key: { text: paymentForLabel },
    value: { text: paymentForValue }
  },
  {
    key: { text: organisationLabel },
    value: { text: organisationValue }
  },
  {
    key: { text: totalAmountLabel },
    value: { text: totalAmountValue }
  }
] %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukPanel({
        titleText: heading.text,
        html: (referenceLabel | escape) + '<br><strong data-testid="payment-reference">' + (paymentReference | escape) + '</strong>',
        classes: 'govuk-!-margin-bottom-8',
        attributes: {
          "data-testid": "app-heading-title"
        }
      }) }}

      <h2 class="govuk-heading-m" data-testid="payment-summary-heading">{{ summaryHeading }}</h2>

      {{ govukSummaryList({
        rows: paymentSummaryRows,
        attributes: {
          "data-testid": "payment-summary-list"
        }
      }) }}

      <h2 class="govuk-heading-m govuk-!-margin-top-8" data-testid="payment-next-steps-heading">{{ whatHappensNextHeading }}</h2>

      {% for nextStep in whatHappensNext %}
        <p class="govuk-body" data-testid="payment-next-step">{{ nextStep }}</p>
      {% endfor %}

      <a class="govuk-link" href="{{ returnToAccountLink}}" data-testid="payment-return-link">{{ returnToAccountLabel }}</a>
    </div>
  </div>
{% endblock %}
